# Canonical site URL for metadata, sitemap, and Open Graph (no trailing slash).
#
# Local development (copy to .env):
NEXT_PUBLIC_APP_URL="http://localhost:3000"
#
# Netlify: Site settings → Environment variables → add the same key with your
# live URL, e.g. https://your-site.netlify.app or https://cepoonjar.ac.in
# NEXT_PUBLIC_APP_URL="https://cepoonjar.ac.in"
